import React, { useState, useEffect } from 'react';
import {
  View,
  Text,
  StyleSheet,
  ScrollView,
  TouchableOpacity,
  SafeAreaView,
  StatusBar,
  useWindowDimensions,
  RefreshControl,
  Alert,
} from 'react-native';
import { useRouter } from 'expo-router';
import Icon from 'react-native-vector-icons/FontAwesome6';
import BottomNav from './components/BottomNav';
import { useData } from './contexts/DataContext';

export default function DashboardScreen() {
  const router = useRouter();
  const { width } = useWindowDimensions();
  const isSmallScreen = width < 375;
  const { 
    stats, 
    invoices, 
    quotations, 
    refreshData,
    formatCurrency,
    deleteInvoice,
    deleteQuotation,
  } = useData();
  
  const [refreshing, setRefreshing] = useState(false);

  const onRefresh = async () => {
    setRefreshing(true);
    await refreshData();
    setRefreshing(false);
  };

  const handleDeleteInvoice = (id: string, invoiceNumber: string) => {
    Alert.alert(
      'Delete Invoice',
      `Are you sure you want to delete invoice ${invoiceNumber}?`,
      [
        { text: 'Cancel', style: 'cancel' },
        { 
          text: 'Delete', 
          style: 'destructive',
          onPress: () => deleteInvoice(id)
        }
      ]
    );
  };

  const handleDeleteQuotation = (id: string, quotationNumber: string) => {
    Alert.alert(
      'Delete Quotation',
      `Are you sure you want to delete quotation ${quotationNumber}?`,
      [
        { text: 'Cancel', style: 'cancel' },
        { 
          text: 'Delete', 
          style: 'destructive',
          onPress: () => deleteQuotation(id)
        }
      ]
    );
  };

  const getStatusColor = (status: string) => {
    switch (status.toLowerCase()) {
      case 'paid':
      case 'accepted':
        return { color: '#10b981', bg: 'rgba(16, 185, 129, 0.1)' };
      case 'pending':
        return { color: '#f59e0b', bg: 'rgba(245, 158, 11, 0.1)' };
      case 'overdue':
      case 'rejected':
      case 'cancelled':
        return { color: '#ef4444', bg: 'rgba(239, 68, 68, 0.1)' };
      case 'draft':
        return { color: '#8E8E93', bg: 'rgba(142, 142, 147, 0.1)' };
      case 'expired':
        return { color: '#64748b', bg: 'rgba(100, 116, 139, 0.1)' };
      default:
        return { color: '#8E8E93', bg: 'rgba(142, 142, 147, 0.1)' };
    }
  };

  const formatDate = (date: Date) => {
    return new Date(date).toLocaleDateString('en-KE', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    });
  };

  const statsData = [
    { 
      icon: 'file-invoice-dollar', 
      color: '#C3B1E1', 
      bgColor: 'rgba(195, 177, 225, 0.1)',
      number: stats.totalInvoices.toString(), 
      label: 'Total Invoices',
    },
    { 
      icon: 'quote-right', 
      color: '#C3B1E1', 
      bgColor: 'rgba(195, 177, 225, 0.1)',
      number: stats.activeQuotes.toString(), 
      label: 'Active Quotes',
    },
    { 
      icon: 'money-bill-wave', 
      color: '#C3B1E1', 
      bgColor: 'rgba(195, 177, 225, 0.1)',
      number: formatCurrency(stats.monthlyRevenue), 
      label: 'Revenue This Month',
    },
    { 
      icon: 'clock', 
      color: '#C3B1E1', 
      bgColor: 'rgba(195, 177, 225, 0.1)',
      number: stats.pendingPayments.toString(), 
      label: 'Pending Payments',
    },
  ];

  const recentInvoices = invoices.slice(0, 3);
  const recentQuotations = quotations.slice(0, 3);

  const renderHeader = () => (
    <View style={[styles.header, isSmallScreen && styles.headerSmall]}>
      <View style={[styles.headerContent, isSmallScreen && styles.headerContentSmall]}>
        <View style={styles.logo}>
          <Icon name="file-invoice-dollar" size={isSmallScreen ? 20 : 24} color="#C3B1E1" />
          <Text style={[styles.logoText, isSmallScreen && styles.logoTextSmall]}>InvoicePro</Text>
        </View>
        <View style={[styles.headerActions, isSmallScreen && styles.headerActionsSmall]}>
          <TouchableOpacity 
            style={[styles.iconButton, isSmallScreen && styles.iconButtonSmall]}
            onPress={onRefresh}
          >
            <Icon name="rotate" size={isSmallScreen ? 16 : 18} color="#C3B1E1" />
          </TouchableOpacity>
          <TouchableOpacity style={[styles.iconButton, isSmallScreen && styles.iconButtonSmall]}>
            <Icon name="bell" size={isSmallScreen ? 16 : 18} color="#C3B1E1" />
          </TouchableOpacity>
          <TouchableOpacity 
            style={[styles.iconButton, isSmallScreen && styles.iconButtonSmall]}
            onPress={() => router.push('/settings')}
          >
            <Icon name="user" size={isSmallScreen ? 16 : 18} color="#C3B1E1" />
          </TouchableOpacity>
        </View>
      </View>
    </View>
  );

  const renderStats = () => {
    const columns = width < 768 ? 2 : 4;
    const itemWidth = (width - 40 - 15) / columns;

    return (
      <View style={[styles.statsGrid, { gap: isSmallScreen ? 10 : 15 }]}>
        {statsData.map((stat, index) => (
          <TouchableOpacity
            key={index}
            style={[
              styles.statCard,
              { 
                width: itemWidth,
                padding: isSmallScreen ? 15 : 20 
              }
            ]}
            activeOpacity={0.9}
            onPress={() => {
              if (index === 0) router.push('/invoices');
              if (index === 1) router.push('/quotations');
            }}
          >
            <View style={[
              styles.statIcon, 
              { 
                backgroundColor: stat.bgColor,
                width: isSmallScreen ? 40 : 50,
                height: isSmallScreen ? 40 : 50,
              }
            ]}>
              <Icon name={stat.icon as any} size={isSmallScreen ? 16 : 20} color={stat.color} />
            </View>
            <View style={styles.statInfo}>
              <Text style={[
                styles.statNumber, 
                isSmallScreen && styles.statNumberSmall
              ]}>
                {stat.number}
              </Text>
              <Text style={[
                styles.statLabel, 
                isSmallScreen && styles.statLabelSmall
              ]}>
                {stat.label}
              </Text>
            </View>
          </TouchableOpacity>
        ))}
      </View>
    );
  };

  const InvoiceItem = ({ invoice }: { invoice: any }) => {
    const status = getStatusColor(invoice.status);
    
    return (
      <TouchableOpacity
        style={styles.invoiceContainer}
        activeOpacity={0.7}
        onPress={() => router.push({
          pathname: '/invoice-detail',
          params: { id: invoice.id }
        })}
      >
        <View style={styles.invoiceHeader}>
          <View style={styles.invoiceIdContainer}>
            <Icon name="file-invoice-dollar" size={16} color="#C3B1E1" />
            <Text style={styles.invoiceId}>{invoice.invoiceNumber}</Text>
          </View>
          <View style={[styles.statusBadge, { backgroundColor: status.bg }]}>
            <Text style={[styles.statusText, { color: status.color }]}>
              {invoice.status.charAt(0).toUpperCase() + invoice.status.slice(1)}
            </Text>
          </View>
        </View>
        
        <View style={styles.invoiceBody}>
          <View style={styles.invoiceRow}>
            <Icon name="building" size={14} color="#8E8E93" />
            <Text style={styles.invoiceClient} numberOfLines={1}>
              {invoice.clientName}
            </Text>
          </View>
          
          <View style={styles.invoiceDetails}>
            <View style={styles.invoiceDetail}>
              <Icon name="calendar" size={12} color="#8E8E93" />
              <Text style={styles.invoiceDetailText}>
                Issued: {formatDate(invoice.issueDate)}
              </Text>
            </View>
            <View style={styles.invoiceDetail}>
              <Icon name="clock" size={12} color="#8E8E93" />
              <Text style={styles.invoiceDetailText}>
                Due: {formatDate(invoice.dueDate)}
              </Text>
            </View>
          </View>
          
          <View style={styles.invoiceAmountRow}>
            <Text style={styles.invoiceAmountLabel}>Amount:</Text>
            <Text style={styles.invoiceAmount}>{formatCurrency(invoice.total)}</Text>
          </View>
        </View>
        
        <View style={styles.invoiceFooter}>
          <View style={styles.invoiceActions}>
            <TouchableOpacity 
              style={styles.invoiceActionButton} 
              onPress={(e) => { 
                e.stopPropagation();
                Alert.alert(
                  'Actions',
                  'Select an action',
                  [
                    { text: 'View', onPress: () => router.push({ pathname: '/invoice-detail', params: { id: invoice.id } }) },
                    { text: 'Download PDF', onPress: () => Alert.alert('Info', 'PDF download feature coming soon') },
                    { text: 'Share', onPress: () => Alert.alert('Info', 'Share feature coming soon') },
                    { text: 'Edit', onPress: () => Alert.alert('Info', 'Edit feature coming soon') },
                    { 
                      text: 'Delete', 
                      style: 'destructive',
                      onPress: () => handleDeleteInvoice(invoice.id, invoice.invoiceNumber)
                    },
                    { text: 'Cancel', style: 'cancel' }
                  ]
                );
              }}
            >
              <Icon name="ellipsis-vertical" size={14} color="#8E8E93" />
            </TouchableOpacity>
          </View>
        </View>
      </TouchableOpacity>
    );
  };

  const QuotationItem = ({ quotation }: { quotation: any }) => {
    const status = getStatusColor(quotation.status);
    
    return (
      <TouchableOpacity
        style={[styles.invoiceContainer, { borderLeftColor: '#C3B1E1' }]}
        activeOpacity={0.7}
        onPress={() => router.push({
          pathname: '/quotation-detail',
          params: { id: quotation.id }
        })}
      >
        <View style={styles.invoiceHeader}>
          <View style={styles.invoiceIdContainer}>
            <Icon name="quote-right" size={16} color="#C3B1E1" />
            <Text style={styles.invoiceId}>{quotation.quotationNumber}</Text>
          </View>
          <View style={[styles.statusBadge, { backgroundColor: status.bg }]}>
            <Text style={[styles.statusText, { color: status.color }]}>
              {quotation.status.charAt(0).toUpperCase() + quotation.status.slice(1)}
            </Text>
          </View>
        </View>
        
        <View style={styles.invoiceBody}>
          <View style={styles.invoiceRow}>
            <Icon name="building" size={14} color="#8E8E93" />
            <Text style={styles.invoiceClient} numberOfLines={1}>
              {quotation.clientName}
            </Text>
          </View>
          
          <View style={styles.invoiceDetails}>
            <View style={styles.invoiceDetail}>
              <Icon name="calendar" size={12} color="#8E8E93" />
              <Text style={styles.invoiceDetailText}>
                Issued: {formatDate(quotation.issueDate)}
              </Text>
            </View>
            <View style={styles.invoiceDetail}>
              <Icon name="hourglass" size={12} color="#8E8E93" />
              <Text style={styles.invoiceDetailText}>
                Valid until: {formatDate(quotation.validUntil)}
              </Text>
            </View>
          </View>
          
          <View style={styles.invoiceAmountRow}>
            <Text style={styles.invoiceAmountLabel}>Amount:</Text>
            <Text style={styles.invoiceAmount}>{formatCurrency(quotation.total)}</Text>
          </View>
        </View>
        
        <View style={styles.invoiceFooter}>
          <View style={styles.invoiceActions}>
            <TouchableOpacity 
              style={styles.invoiceActionButton} 
              onPress={(e) => { 
                e.stopPropagation();
                Alert.alert(
                  'Actions',
                  'Select an action',
                  [
                    { text: 'View', onPress: () => router.push({ pathname: '/quotation-detail', params: { id: quotation.id } }) },
                    { text: 'Download PDF', onPress: () => Alert.alert('Info', 'PDF download feature coming soon') },
                    { text: 'Share', onPress: () => Alert.alert('Info', 'Share feature coming soon') },
                    { text: 'Edit', onPress: () => Alert.alert('Info', 'Edit feature coming soon') },
                    { 
                      text: 'Delete', 
                      style: 'destructive',
                      onPress: () => handleDeleteQuotation(quotation.id, quotation.quotationNumber)
                    },
                    { text: 'Cancel', style: 'cancel' }
                  ]
                );
              }}
            >
              <Icon name="ellipsis-vertical" size={14} color="#8E8E93" />
            </TouchableOpacity>
          </View>
        </View>
      </TouchableOpacity>
    );
  };

  const renderRecentInvoices = () => (
    <View style={styles.sectionContainer}>
      <View style={[styles.cardHeader, isSmallScreen && styles.cardHeaderSmall]}>
        <Text style={[styles.cardTitle, isSmallScreen && styles.cardTitleSmall]}>Recent Invoices</Text>
        <TouchableOpacity 
          style={[styles.viewAllButton, isSmallScreen && styles.viewAllButtonSmall]}
          onPress={() => router.push('/invoices')}
        >
          <Text style={[styles.viewAllText, isSmallScreen && styles.viewAllTextSmall]}>View All</Text>
          <Icon name="chevron-right" size={12} color="#C3B1E1" style={{ marginLeft: 4 }} />
        </TouchableOpacity>
      </View>
      
      {recentInvoices.length > 0 ? (
        <View style={styles.invoiceList}>
          {recentInvoices.map((invoice, index) => (
            <InvoiceItem key={invoice.id} invoice={invoice} />
          ))}
        </View>
      ) : (
        <View style={styles.emptyState}>
          <Icon name="file-invoice" size={40} color="#8E8E93" />
          <Text style={styles.emptyStateText}>No invoices yet</Text>
          <Text style={styles.emptyStateSubtext}>Create your first invoice to get started</Text>
          <TouchableOpacity 
            style={styles.emptyStateButton}
            onPress={() => router.push('/create-options')}
          >
            <Icon name="plus" size={16} color="#000000" />
            <Text style={styles.emptyStateButtonText}>Create Invoice</Text>
          </TouchableOpacity>
        </View>
      )}
    </View>
  );

  const renderRecentQuotations = () => (
    <View style={styles.sectionContainer}>
      <View style={[styles.cardHeader, isSmallScreen && styles.cardHeaderSmall]}>
        <Text style={[styles.cardTitle, isSmallScreen && styles.cardTitleSmall]}>Recent Quotes</Text>
        <TouchableOpacity 
          style={[styles.viewAllButton, isSmallScreen && styles.viewAllButtonSmall]}
          onPress={() => router.push('/quotations')}
        >
          <Text style={[styles.viewAllText, isSmallScreen && styles.viewAllTextSmall]}>View All</Text>
          <Icon name="chevron-right" size={12} color="#C3B1E1" style={{ marginLeft: 4 }} />
        </TouchableOpacity>
      </View>
      
      {recentQuotations.length > 0 ? (
        <View style={styles.invoiceList}>
          {recentQuotations.map((quotation, index) => (
            <QuotationItem key={quotation.id} quotation={quotation} />
          ))}
        </View>
      ) : (
        <View style={styles.emptyState}>
          <Icon name="quote-right" size={40} color="#8E8E93" />
          <Text style={styles.emptyStateText}>No quotations yet</Text>
          <Text style={styles.emptyStateSubtext}>Create your first quotation to get started</Text>
          <TouchableOpacity 
            style={[styles.emptyStateButton, { backgroundColor: '#C3B1E1' }]}
            onPress={() => router.push('/create-options')}
          >
            <Icon name="plus" size={16} color="#000000" />
            <Text style={styles.emptyStateButtonText}>Create Quotation</Text>
          </TouchableOpacity>
        </View>
      )}
    </View>
  );

  return (
    <SafeAreaView style={styles.container}>
      <StatusBar barStyle="light-content" backgroundColor="#000000" />
      {renderHeader()}
      <ScrollView 
        style={styles.mainContent}
        showsVerticalScrollIndicator={false}
        contentContainerStyle={[
          styles.scrollContent,
          { paddingBottom: isSmallScreen ? 100 : 120 }
        ]}
        refreshControl={
          <RefreshControl
            refreshing={refreshing}
            onRefresh={onRefresh}
            tintColor="#C3B1E1"
            colors={['#C3B1E1']}
          />
        }
      >
        <Text style={[styles.pageTitle, isSmallScreen && styles.pageTitleSmall]}>
          Dashboard
        </Text>
        {renderStats()}
        {renderRecentInvoices()}
        {renderRecentQuotations()}
      </ScrollView>
      <BottomNav />
    </SafeAreaView>
  );
}

