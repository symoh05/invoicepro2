import React, { useEffect } from 'react';
import { Stack } from 'expo-router';
import { StatusBar } from 'expo-status-bar';
import { SafeAreaProvider, SafeAreaView } from 'react-native-safe-area-context';
import { GestureHandlerRootView } from 'react-native-gesture-handler';
import { StyleSheet, View, Platform } from 'react-native';
import * as SplashScreen from 'expo-splash-screen';
import { DataProvider } from './contexts/DataContext';

// Keep splash screen visible
SplashScreen.preventAutoHideAsync();

export default function RootLayout() {
  useEffect(() => {
    // Hide splash screen after 500ms
    const timer = setTimeout(() => {
      SplashScreen.hideAsync();
    }, 500);

    return () => clearTimeout(timer);
  }, []);

  return (
    <GestureHandlerRootView style={styles.container}>
      {/* Outer container with black background */}
      <View style={styles.outerContainer}>
        <StatusBar 
          style="light" 
          backgroundColor="#000000"
          translucent={false}
          animated={false}
        />
        
        <SafeAreaProvider>
          {/* SafeAreaView with black background to prevent system color flashes */}
          <SafeAreaView style={styles.safeArea} edges={['top', 'left', 'right']}>
            <DataProvider>
              <Stack
                screenOptions={{
                  // Navigation settings
                  headerShown: false,
                  animation: 'none',
                  gestureEnabled: false,
                  animationDuration: 0,
                  
                  // Background and presentation settings
                  contentStyle: { backgroundColor: '#000000' },
                  presentation: 'card',
                  
                  // Performance optimizations
                  freezeOnBlur: true,
                  lazy: true,
                  
                  // Remove any default system styling
                  headerStyle: { backgroundColor: '#000000' },
                  headerTintColor: '#FFFFFF',
                  headerBackTitleVisible: false,
                  
                  // Platform specific fixes
                  ...Platform.select({
                    ios: {
                      gestureDirection: 'horizontal',
                      headerShadowVisible: false,
                    },
                    android: {
                      headerLargeTitle: false,
                      headerBackButtonMenuEnabled: false,
                    },
                  }),
                }}
              >
                {/* Home Dashboard */}
                <Stack.Screen 
                  name="index" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                    statusBarStyle: 'light',
                    statusBarColor: '#000000',
                    statusBarTranslucent: false,
                  }}
                />
                
                {/* Invoices Section */}
                <Stack.Screen 
                  name="invoices" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* Quotations Section */}
                <Stack.Screen 
                  name="quotations" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* More Options */}
                <Stack.Screen 
                  name="more" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* Create Options */}
                <Stack.Screen 
                  name="create-options" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* Create Invoice */}
                <Stack.Screen 
                  name="create-invoice" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                    // Force specific settings for this screen
                    animation: 'none',
                    gestureEnabled: false,
                  }}
                />
                
                {/* Create Quotation */}
                <Stack.Screen 
                  name="create-quotation" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                    animation: 'none',
                    gestureEnabled: false,
                  }}
                />
                
                {/* Invoice Detail */}
                <Stack.Screen 
                  name="invoice-detail" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                    presentation: 'modal',
                  }}
                />
                
                {/* Quotation Detail */}
                <Stack.Screen 
                  name="quotation-detail" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                    presentation: 'modal',
                  }}
                />
                
                {/* Add Client */}
                <Stack.Screen 
                  name="add-client" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* Clients Screen */}
                <Stack.Screen 
                  name="clients" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* Templates */}
                <Stack.Screen 
                  name="templates" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* Settings */}
                <Stack.Screen 
                  name="settings" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
                
                {/* Products Screen */}
                <Stack.Screen 
                  name="products" 
                  options={{
                    contentStyle: { backgroundColor: '#000000' },
                  }}
                />
              </Stack>
            </DataProvider>
          </SafeAreaView>
        </SafeAreaProvider>
      </View>
    </GestureHandlerRootView>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
  },
  outerContainer: {
    flex: 1,
    backgroundColor: '#000000', // Pure black for entire app
  },
  safeArea: {
    flex: 1,
    backgroundColor: '#000000', // Black for safe area
  },
});